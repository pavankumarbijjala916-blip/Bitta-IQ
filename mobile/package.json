{
  "name": "battery-buddy-mobile",
  "version": "1.0.0",
  "description": "Green Battery Buddy - Mobile App (iOS & Android)",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "eject": "expo eject",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "test": "jest"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.0",
    "@react-native-picker/picker": "^2.6.0",
    "expo": "^50.0.0",
    "expo-splash-screen": "~0.27.4",
    "expo-status-bar": "~1.11.1",
    "expo-font": "~11.10.0",
    "expo-notifications": "~0.27.6",
    "expo-camera": "~14.1.0",
    "expo-image-picker": "~14.7.1",
    "expo-auth-session": "~5.4.0",
    "expo-web-browser": "~12.8.0",
    "firebase": "^10.7.0",
    "@react-native-firebase/app": "^18.8.0",
    "@react-native-firebase/auth": "^18.8.0",
    "@react-native-firebase/firestore": "^18.8.0",
    "@react-native-firebase/database": "^18.8.0",
    "@react-native-firebase/messaging": "^18.8.0",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "react-native-gesture-handler": "^2.14.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.8",
    "@react-navigation/native-stack": "^6.9.17",
    "react-native-screens": "^3.27.0",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-svg": "^14.1.0",
    "react-native-vector-icons": "^10.0.0",
    "react-native-calendars": "^1.1304.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "^3.6.0",
    "zustand": "^4.4.0",
    "axios": "^1.6.0",
    "date-fns": "^2.30.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@types/react-native-vector-icons": "^6.4.0",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.0.0",
    "react-test-renderer": "18.2.0"
  },
  "private": true,
  "expo": {
    "name": "Battery Buddy",
    "slug": "battery-buddy-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.batterbuddy.mobile",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.batterbuddy.mobile",
      "versionCode": 1
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Battery Buddy to access your camera"
        }
      ]
    ]
  }
}
