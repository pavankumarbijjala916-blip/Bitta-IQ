# BATT IQ Environment Configuration
# Copy this file to .env and update with your actual values

# ========== FIREBASE CONFIGURATION ==========
# Get these from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ========== EMAIL NOTIFICATION CONFIGURATION ==========
# Email notifications are logged locally by default.
# To enable actual email sending, configure one of the options below:

# Option 1: Using a Node.js backend server (Recommended for production)
# Set up your notification API backend and configure these:
VITE_NOTIFICATION_API_URL=http://localhost:5001/api/notifications
VITE_NOTIFICATION_API_KEY=your_api_key_here

# Option 2: Direct SendGrid Integration (Simple setup)
VITE_SENDGRID_API_KEY=your_sendgrid_api_key
VITE_SENDGRID_FROM_EMAIL=noreply@batt-iq.app

# Option 3: Other Email Services
# VITE_EMAIL_SERVICE=sendgrid  # or 'smtp', 'mailgun', etc.
# VITE_EMAIL_API_KEY=your_email_service_api_key

# NOTE: Currently, emails are logged locally in the browser console and localStorage.
# Check the browser console for 📧 EMAIL LOG entries after registering a battery.
# In development, you can access logs via: notificationService.getEmailLogs()

# ========== ML SERVICE CONFIGURATION ==========
# URL of your ML prediction API
VITE_ML_API_URL=http://localhost:5000/api/ml
# or for production: https://ml-service.your-domain.com/api/ml

# API Key for ML service authentication
VITE_ML_API_KEY=your_ml_api_key

# ========== NOTIFICATION SERVICE CONFIGURATION ==========
VITE_NOTIFICATION_API_URL=http://localhost:5001/api/notifications
# or for production: https://notification-service.your-domain.com/api/notifications

VITE_NOTIFICATION_API_KEY=your_notification_api_key

# ========== SENDGRID CONFIGURATION (Optional) ==========
# For email notifications
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@batt-iq.app

# ========== APPLICATION CONFIGURATION ==========
# Application environment
VITE_ENV=development
# or for production: production

# Application URL
VITE_APP_URL=http://localhost:5173
# or for production: https://batt-iq.app

# Enable debug logging
VITE_DEBUG_MODE=true
# or for production: false

# ========== ANALYTICS CONFIGURATION ==========
VITE_ANALYTICS_ENABLED=true
VITE_SENTRY_DSN=your_sentry_dsn_url

# ========== FEATURE FLAGS ==========
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_ML_PREDICTIONS=true
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true

# ========== DEVELOPMENT SETTINGS ==========
# API timeout in milliseconds
VITE_API_TIMEOUT=10000

# Maximum batch size for operations
VITE_MAX_BATCH_SIZE=100

# Cache duration in seconds
VITE_CACHE_DURATION=300

# ========== SECURITY SETTINGS ==========
# API rate limiting (requests per minute)
VITE_RATE_LIMIT=60

# Session timeout in minutes
VITE_SESSION_TIMEOUT=30

# ========== REGIONAL SETTINGS ==========
VITE_DEFAULT_TIMEZONE=UTC
VITE_DEFAULT_LANGUAGE=en
VITE_DEFAULT_CURRENCY=USD
